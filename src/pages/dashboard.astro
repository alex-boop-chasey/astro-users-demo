---
import Layout from '../layouts/Layout.astro';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/login');
}

const userName = user.user_metadata?.name || 'Developer';
const userEmail = user.email || '';
const joinDate = user.created_at ? new Date(user.created_at).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}) : 'N/A';
---

<Layout>
  <div class="dashboard-container">
    <!-- Background elements -->
    <div class="glow-mesh-top"></div>
    <div class="glow-mesh-bottom"></div>

    <!-- Header -->
    <header class="dashboard-header">
      <div class="header-inner">
        <div class="logo">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="logo-icon">
            <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
            <path d="M2 17l10 5 10-5"></path>
            <path d="M2 12l10 5 10-5"></path>
          </svg>
          <span>AstroAuth</span>
        </div>
        
        <div class="user-menu">
          <div class="user-avatar-circle">
            {userName.charAt(0).toUpperCase()}
          </div>
          <span class="user-display-name">{userName}</span>
          <button id="btn-signout" class="btn-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="btn-icon">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
              <polyline points="16 17 21 12 16 7"></polyline>
              <line x1="21" y1="12" x2="9" y2="12"></line>
            </svg>
            Sign Out
          </button>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="dashboard-main">
      <div class="dashboard-content">
        <!-- Welcome Card -->
        <section class="welcome-card">
          <div class="welcome-text">
            <span class="badge">Astro Community Member</span>
            <h1>Welcome, {userName}!</h1>
            <p>You have successfully logged in using your Supabase account. Your session is protected by Cloudflare Turnstile CAPTCHA.</p>
          </div>
          <div class="welcome-stats">
            <div class="stat-pill">
              <span class="stat-label">Active Session</span>
              <span class="stat-value text-success">Verified</span>
            </div>
            <div class="stat-pill">
              <span class="stat-label">Joined</span>
              <span class="stat-value">{joinDate}</span>
            </div>
          </div>
        </section>

        <!-- Grid Cards -->
        <div class="dashboard-grid">
          <!-- Card 1: User Profile -->
          <div class="info-card">
            <div class="card-icon-wrapper purple">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
            </div>
            <h3>Account Details</h3>
            <p>View the active session metadata retrieved securely from Supabase.</p>
            <div class="metadata-list">
              <div class="metadata-item">
                <span class="label">Email</span>
                <span class="value">{userEmail}</span>
              </div>
              <div class="metadata-item">
                <span class="label">User ID</span>
                <span class="value code">{user.id}</span>
              </div>
              <div class="metadata-item">
                <span class="label">Provider</span>
                <span class="value capitalize">{user.app_metadata?.provider || 'Email'}</span>
              </div>
            </div>
          </div>

          <!-- Card 2: Environment Info -->
          <div class="info-card">
            <div class="card-icon-wrapper indigo">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                <line x1="8" y1="21" x2="16" y2="21"></line>
                <line x1="12" y1="17" x2="12" y2="21"></line>
              </svg>
            </div>
            <h3>Environment Status</h3>
            <p>System environments and integrations active for this build.</p>
            <div class="metadata-list">
              <div class="metadata-item">
                <span class="label">Astro Output</span>
                <span class="value code">server</span>
              </div>
              <div class="metadata-item">
                <span class="label">CSRF Shield</span>
                <span class="value text-success">Turnstile Active</span>
              </div>
              <div class="metadata-item">
                <span class="label">Database</span>
                <span class="value">Supabase PostgreSQL</span>
              </div>
            </div>
          </div>

          <!-- Card 3: Community Card -->
          <div class="info-card promo">
            <div class="card-glow"></div>
            <div class="card-icon-wrapper pink">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
              </svg>
            </div>
            <h3>Astro Community</h3>
            <p>Ready to deploy? Share your custom authorization layouts on the Astro Community site to help others implement secure auth.</p>
            <a href="https://astro.build/chat" target="_blank" rel="noopener noreferrer" class="btn-primary-gradient">
              Join Astro Discord
            </a>
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<script>
  import { actions } from 'astro:actions';

  const signoutBtn = document.getElementById('btn-signout');

  signoutBtn?.addEventListener('click', async () => {
    // Disable button to prevent double-clicks
    if (signoutBtn instanceof HTMLButtonElement) {
      signoutBtn.disabled = true;
    }

    try {
      const { error } = await actions.signOut();
      if (!error) {
        // Redirect back to login
        window.location.href = '/login';
      } else {
        console.error('Failed to sign out:', error.message);
        if (signoutBtn instanceof HTMLButtonElement) {
          signoutBtn.disabled = false;
        }
      }
    } catch (err) {
      console.error('Sign out error:', err);
      if (signoutBtn instanceof HTMLButtonElement) {
        signoutBtn.disabled = false;
      }
    }
  });
</script>

<style>
  :root {
    --color-bg-mesh-1: rgba(99, 102, 241, 0.12);
    --color-bg-mesh-2: rgba(168, 85, 247, 0.12);
    --color-primary: #6366f1;
    --color-primary-hover: #4f46e5;
    --color-accent: #a855f7;
    --color-pink: #ec4899;
    --color-text-base: #f4f4f5;
    --color-text-muted: #a1a1aa;
    --color-card-bg: rgba(24, 24, 27, 0.6);
    --color-input-bg: rgba(9, 9, 11, 0.5);
    --color-border: rgba(255, 255, 255, 0.08);
    --color-error: #ef4444;
    --color-success: #10b981;
    --shadow-premium: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    --font-family: 'Plus Jakarta Sans', 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  .dashboard-container {
    min-height: 100vh;
    background-color: #030014;
    color: var(--color-text-base);
    font-family: var(--font-family);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* Glow effects */
  .glow-mesh-top {
    position: absolute;
    top: -200px;
    left: 20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, var(--color-bg-mesh-1) 0%, transparent 70%);
    filter: blur(100px);
    pointer-events: none;
  }

  .glow-mesh-bottom {
    position: absolute;
    bottom: -200px;
    right: 20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, var(--color-bg-mesh-2) 0%, transparent 70%);
    filter: blur(100px);
    pointer-events: none;
  }

  /* Header styles */
  .dashboard-header {
    background: rgba(3, 0, 20, 0.5);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 1.25rem;
    background: linear-gradient(135deg, #818cf8 0%, #c084fc 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .logo-icon {
    width: 24px;
    height: 24px;
    stroke: #818cf8;
  }

  .user-menu {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .user-avatar-circle {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    color: #ffffff;
    font-size: 0.9375rem;
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
  }

  .user-display-name {
    font-weight: 600;
    font-size: 0.9375rem;
    max-width: 150px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Buttons */
  .btn-secondary {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--color-border);
    color: var(--color-text-base);
    border-radius: 10px;
    padding: 8px 14px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.2s ease;
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.15);
  }

  .btn-secondary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-icon {
    width: 16px;
    height: 16px;
  }

  /* Main Layout */
  .dashboard-main {
    flex: 1;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 40px 24px;
    box-sizing: border-box;
    z-index: 1;
  }

  .dashboard-content {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* Welcome Card styling */
  .welcome-card {
    background: var(--color-card-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 32px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 24px;
    box-shadow: var(--shadow-premium);
  }

  .welcome-text h1 {
    font-size: 2.25rem;
    font-weight: 800;
    margin: 8px 0 12px 0;
    letter-spacing: -1px;
    background: linear-gradient(to right, #ffffff, #d4d4d8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .welcome-text p {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
    max-width: 600px;
  }

  .badge {
    background: rgba(99, 102, 241, 0.15);
    color: #a5b4fc;
    border: 1px solid rgba(99, 102, 241, 0.25);
    border-radius: 99px;
    padding: 4px 12px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    display: inline-block;
  }

  .welcome-stats {
    display: flex;
    gap: 16px;
  }

  .stat-pill {
    background: rgba(9, 9, 11, 0.5);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 120px;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .stat-value {
    font-size: 1.125rem;
    font-weight: 700;
  }

  .text-success {
    color: var(--color-success);
  }

  /* Grid details */
  .dashboard-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 24px;
  }

  .info-card {
    background: var(--color-card-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 32px;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 16px;
    box-shadow: var(--shadow-premium);
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .info-card:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.15);
  }

  .card-icon-wrapper {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-icon-wrapper svg {
    width: 24px;
    height: 24px;
  }

  .card-icon-wrapper.purple {
    background: rgba(168, 85, 247, 0.15);
    color: #d8b4fe;
    border: 1px solid rgba(168, 85, 247, 0.25);
  }

  .card-icon-wrapper.indigo {
    background: rgba(99, 102, 241, 0.15);
    color: #c7d2fe;
    border: 1px solid rgba(99, 102, 241, 0.25);
  }

  .card-icon-wrapper.pink {
    background: rgba(236, 72, 153, 0.15);
    color: #fbcfe8;
    border: 1px solid rgba(236, 72, 153, 0.25);
  }

  .info-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
    letter-spacing: -0.3px;
  }

  .info-card p {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 0;
  }

  .metadata-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 8px;
    border-top: 1px solid var(--color-border);
    padding-top: 16px;
  }

  .metadata-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    font-size: 0.8125rem;
  }

  .metadata-item .label {
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .metadata-item .value {
    font-weight: 600;
    text-align: right;
    max-width: 180px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .metadata-item .value.code {
    font-family: monospace;
    color: #e4e4e7;
    background: rgba(255, 255, 255, 0.05);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.75rem;
  }

  .capitalize {
    text-transform: capitalize;
  }

  /* Community promo card styling */
  .info-card.promo {
    background: radial-gradient(circle at top right, rgba(236, 72, 153, 0.1) 0%, rgba(9, 9, 11, 0.5) 100%);
    border-color: rgba(236, 72, 153, 0.2);
    justify-content: space-between;
  }

  .card-glow {
    position: absolute;
    top: 0;
    right: 0;
    width: 150px;
    height: 150px;
    background: radial-gradient(circle, rgba(236, 72, 153, 0.15) 0%, transparent 70%);
    filter: blur(20px);
    pointer-events: none;
  }

  .btn-primary-gradient {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
    border: none;
    border-radius: 12px;
    color: #ffffff;
    font-size: 0.875rem;
    font-weight: 600;
    padding: 12px;
    text-align: center;
    cursor: pointer;
    text-decoration: none;
    display: block;
    margin-top: 16px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 14px rgba(99, 102, 241, 0.15);
  }

  .btn-primary-gradient:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(99, 102, 241, 0.3);
    filter: brightness(1.05);
  }

  /* Responsive styling */
  @media (max-width: 768px) {
    .welcome-card {
      padding: 24px;
    }
    .welcome-text h1 {
      font-size: 1.75rem;
    }
    .welcome-stats {
      width: 100%;
    }
    .stat-pill {
      flex: 1;
    }
  }
</style>
